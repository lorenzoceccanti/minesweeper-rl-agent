# Esclude tutti i file generati da macOS che iniziano per ._
**/._*

# Esclude altri file di sistema macOS comuni
.DS_Store
.AppleDouble
.LSOverride

# Python
__pycache__/
*.pyc

# Environments
.env
.venv/
env/
venv/

# Esclude file creati dall'editor VS Code
.vscode/

# Esclude i file temporanei, compresi i main di prova
tmp/

# Esclude directory di tool vari
.claude/
.tokensave/
.serena/
graphify-out/
.graphify*

# LaTeX build output (report/)
report/build/*
!report/build/slides.pdf
report/indent.log
/log
checkpoints/*
!checkpoints/*/
checkpoints/*/*
!checkpoints/*/best/
/plots

# Weights & Biases local run cache
wandb/
sweeps/logs/
/csv
